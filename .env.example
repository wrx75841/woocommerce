# Skopiuj ten plik do .env i uzupelnij wedlug potrzeb:
#   cp .env.example .env
#
# docker compose wczytuje plik .env automatycznie. Wartosci ponizej to
# defaulty uzywane rowniez, gdy .env w ogole nie istnieje (patrz
# "${ZMIENNA:-wartosc}" w docker-compose.yml) - wiec sam plik .env jest
# opcjonalny, poza sekcja ngrok.

# --- Baza danych ---
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress
MYSQL_ROOT_PASSWORD=rootpassword

# --- WordPress ---
WP_PORT=8080
WP_TITLE=Test Store
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin123
WP_ADMIN_EMAIL=admin@example.com

# --- ngrok (wymagane TYLKO przy: docker compose --profile public up -d) ---
# Token: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# Staly, zarezerwowany adres z konta ngrok (opcjonalnie). Bez tego ngrok
# wygeneruje losowy adres *.ngrok-free.app przy kazdym starcie kontenera.
# Zeby ta wartosc zadzialala, trzeba tez odkomentowac linie
# "--url=${NGROK_DOMAIN}" w docker-compose.yml (usluga ngrok).
NGROK_DOMAIN=

# --- WooCommerce REST API (opcjonalne, do integracji zewnetrznych aplikacji) ---
# Generuje sie w panelu: WooCommerce -> Ustawienia -> Zaawansowane -> REST API -> Dodaj klucz
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=
